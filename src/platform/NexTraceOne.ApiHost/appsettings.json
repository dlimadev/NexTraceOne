{
  "ConnectionStrings": {
    "NexTraceOne": "Host=localhost;Port=5432;Database=nextraceone;Username=nextraceone;Password=REPLACE_VIA_ENV;Maximum Pool Size=10",
    "IdentityDatabase": "Host=localhost;Port=5432;Database=nextraceone;Username=nextraceone;Password=REPLACE_VIA_ENV;Maximum Pool Size=10",
    "ServiceCatalogDatabase": "Host=localhost;Port=5432;Database=nextraceone;Username=nextraceone;Password=REPLACE_VIA_ENV;Maximum Pool Size=10",
    "ChangeGovernanceDatabase": "Host=localhost;Port=5432;Database=nextraceone;Username=nextraceone;Password=REPLACE_VIA_ENV;Maximum Pool Size=10",
    "IncidentResponseDatabase": "Host=localhost;Port=5432;Database=nextraceone;Username=nextraceone;Password=REPLACE_VIA_ENV;Maximum Pool Size=10",
    "GovernanceDatabase": "Host=localhost;Port=5432;Database=nextraceone;Username=nextraceone;Password=REPLACE_VIA_ENV;Maximum Pool Size=10",
    "AiHubDatabase": "Host=localhost;Port=5432;Database=nextraceone;Username=nextraceone;Password=REPLACE_VIA_ENV;Maximum Pool Size=10",
    "IntegrationsDatabase": "Host=localhost;Port=5432;Database=nextraceone;Username=nextraceone;Password=REPLACE_VIA_ENV;Maximum Pool Size=10",
    "ConfigurationDatabase": "Host=localhost;Port=5432;Database=nextraceone;Username=nextraceone;Password=REPLACE_VIA_ENV;Maximum Pool Size=10"
  },
  "NexTraceOne": {
    "IntegrityCheck": true,
    "PerformanceThresholdMs": 500,
    "Tenant": {
      "ResolutionStrategy": "JwtClaim"
    }
  },
  "Jwt": {
    "Issuer": "NexTraceOne",
    "Audience": "nextraceone-api",
    "AccessTokenExpirationMinutes": 60,
    "RefreshTokenExpirationDays": 7
  },
  "AiRuntime": {
    "Ollama": {
      "BaseUrl": "http://localhost:11434",
      "TimeoutSeconds": 120,
      "MaxRetries": 2,
      "DefaultChatModel": "llama3.2:3b",
      "DefaultReasoningModel": "phi3.5:3.8b",
      "DefaultEmbeddingModel": "nomic-embed-text",
      "Enabled": true
    },
    "OpenAI": {
      "BaseUrl": "https://api.openai.com",
      "ApiKey": "",
      "DefaultChatModel": "gpt-4o-mini",
      "TimeoutSeconds": 60,
      "DefaultTemperature": 0.3,
      "DefaultMaxTokens": 4096,
      "Enabled": false
    },
    "Anthropic": {
      "ApiKey": "",
      "DefaultChatModel": "claude-sonnet-4-6",
      "DefaultReasoningModel": "claude-opus-4-7",
      "DefaultFastModel": "claude-haiku-4-5",
      "TimeoutSeconds": 90,
      "DefaultTemperature": 0.3,
      "DefaultMaxTokens": 4096,
      "Enabled": false
    },
    "Routing": {
      "PreferredProvider": "ollama",
      "PreferredChatModel": "llama3.2:3b",
      "EnableDeterministicFallback": true,
      "FallbackPrefix": "[FALLBACK_PROVIDER_UNAVAILABLE]"
    },
    "TokenQuota": {
      "DefaultMaxTokensPerRequestInput": 8000,
      "DefaultMaxTokensPerRequestOutput": 4096,
      "DefaultMaxTokensPerDayPerUser": 100000,
      "DefaultMaxTokensPerMonthPerTenant": 5000000,
      "IsHardLimit": true
    }
  },
  "Auth": {
    "CookieSession": {
      "Enabled": true,
      "AccessTokenCookieName": "nxt_at",
      "CsrfCookieName": "nxt_csrf",
      "CsrfHeaderName": "X-Csrf-Token",
      "AccessTokenCookieExpirationMinutes": 60,
      "RequireSecureCookies": true
    }
  },
  "OidcProviders": {
    "azure": {
      "Authority": "https://login.microsoftonline.com/{tenant-id}/v2.0",
      "ClientId": "",
      "ClientSecret": "",
      "Scopes": "openid profile email"
    }
  },
  "Cors": {
    "AllowedOrigins": []
  },
  "Security": {
    "AllowedOrigins": {
      "Allowed": [ "http://localhost:3000", "https://localhost:3000" ]
    }
  },
  "RateLimiting": {
    "Global": {
      "PermitLimit": 100,
      "UnresolvedIpPermitLimit": 20,
      "WindowMinutes": 1,
      "QueueLimit": 5
    },
    "Auth": {
      "PermitLimit": 20,
      "WindowMinutes": 1,
      "QueueLimit": 2
    },
    "AuthSensitive": {
      "PermitLimit": 10,
      "WindowMinutes": 1,
      "QueueLimit": 2
    },
    "Ai": {
      "PermitLimit": 30,
      "WindowMinutes": 1,
      "QueueLimit": 3
    },
    "DataIntensive": {
      "PermitLimit": 50,
      "WindowMinutes": 1,
      "QueueLimit": 3
    },
    "Operations": {
      "PermitLimit": 40,
      "WindowMinutes": 1,
      "QueueLimit": 3
    }
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console"
      },
      {
        "Name": "File",
        "Args": {
          "path": "logs/nextraceone-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 30
        }
      }
    ]
  },
  "OpenTelemetry": {
    "_comment": "ServiceName mantido aqui por backwards-compat. Endpoint consolidado em Telemetry:Collector:OtlpGrpcEndpoint.",
    "ServiceName": "nextraceone-apihost"
  },
  "Telemetry": {
    "ProductStore": {
      "ConnectionStringName": "NexTraceOne",
      "Schema": "telemetry",
      "EnableTimePartitioning": true,
      "MinuteMetricsPartitionInterval": "1 day",
      "HourlyMetricsPartitionInterval": "1 month"
    },
    "ObservabilityProvider": {
      "Provider": "ClickHouse",
      "ClickHouse": {
        "Enabled": true,
        "ConnectionString": "Host=localhost;Port=8123;Database=nextraceone_obs;Username=default;Password=",
        "Database": "nextraceone_obs",
        "LogsRetentionDays": 30,
        "TracesRetentionDays": 30,
        "MetricsRetentionDays": 90
      }
    },
    "CollectionMode": {
      "ActiveMode": "OpenTelemetryCollector",
      "OpenTelemetryCollector": {
        "Enabled": true,
        "OtlpGrpcEndpoint": "",
        "OtlpHttpEndpoint": ""
      },
      "ClrProfiler": {
        "Enabled": false,
        "Mode": "IIS",
        "ProfilerType": "AutoInstrumentation",
        "ExportTarget": "Collector",
        "OtlpEndpoint": ""
      }
    },
    "Collector": {
      "OtlpGrpcEndpoint": "",
      "OtlpHttpEndpoint": "",
      "MemoryLimitMb": 512,
      "MemorySpikeLimitMb": 128,
      "BatchSize": 8192,
      "BatchTimeoutMs": 5000,
      "TracesSamplingRate": 1.0
    },
    "Retention": {
      "RawTraces": {
        "HotDays": 7,
        "WarmDays": 30,
        "ColdDays": 0
      },
      "RawLogs": {
        "HotDays": 7,
        "WarmDays": 30,
        "ColdDays": 0
      },
      "MinuteAggregates": {
        "HotDays": 7,
        "WarmDays": 0,
        "ColdDays": 0
      },
      "HourlyAggregates": {
        "HotDays": 90,
        "WarmDays": 365,
        "ColdDays": 0
      },
      "Snapshots": {
        "HotDays": 90,
        "WarmDays": 365,
        "ColdDays": 0
      },
      "ObservedTopology": {
        "HotDays": 90,
        "WarmDays": 0,
        "ColdDays": 0
      },
      "AuditCompliance": {
        "HotDays": 365,
        "WarmDays": 0,
        "ColdDays": 2555
      }
    }
  },
  "ClickHouse": {
    "LegacyTelemetry": {
      "Endpoint": "http://localhost:8123",
      "DefaultTenantId": null,
      "SuppressWriteErrors": true
    }
  },
  "Analytics": {
    "Enabled": true,
    "ConnectionString": "http://localhost:8123",
    "WriteTimeoutSeconds": 10,
    "MaxBatchSize": 500,
    "SuppressWriteErrors": true
  }
}
