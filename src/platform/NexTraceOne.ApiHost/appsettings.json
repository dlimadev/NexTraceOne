  "NexTraceOne": {
    "IntegrityCheck": true,
    "PerformanceThresholdMs": 500,
    "Tenant": {
      "ResolutionStrategy": "JwtClaim"
    }
  },
  "Jwt": {
    "Issuer": "NexTraceOne",
    "Audience": "nextraceone-api",
    "Secret": "",
    "AccessTokenExpirationMinutes": 60,
    "RefreshTokenExpirationDays": 7
  },
  "AiRuntime": {
    "Ollama": {
      "BaseUrl": "http://localhost:11434",
      "TimeoutSeconds": 120,
      "MaxRetries": 2,
      "DefaultChatModel": "qwen3.5:9b",
      "Enabled": true
    },
    "OpenAI": {
      "BaseUrl": "https://api.openai.com",
      "ApiKey": "",
      "DefaultChatModel": "gpt-4o-mini",
      "TimeoutSeconds": 60,
      "DefaultTemperature": 0.3,
      "DefaultMaxTokens": 2048,
      "Enabled": false
    },
    "Routing": {
      "PreferredProvider": "ollama",
      "PreferredChatModel": "qwen3.5:9b",
      "EnableDeterministicFallback": true,
      "FallbackPrefix": "[FALLBACK_PROVIDER_UNAVAILABLE]"
    }
  },
  "Auth": {
    "CookieSession": {
      "Enabled": true,
      "AccessTokenCookieName": "nxt_at",
      "CsrfCookieName": "nxt_csrf",
      "CsrfHeaderName": "X-Csrf-Token",
      "AccessTokenCookieExpirationMinutes": 60,
      "RequireSecureCookies": true
    }
  },
  "OidcProviders": {
    "azure": {
      "Authority": "https://login.microsoftonline.com/{tenant-id}/v2.0",
      "ClientId": "",
      "ClientSecret": "",
      "Scopes": "openid profile email"
    }
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:5173",
      "http://localhost:3000"
    ]
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console"
      },
      {
        "Name": "File",
        "Args": {
          "path": "logs/nextraceone-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 30
        }
      }
    ]
  },
  "OpenTelemetry": {
    "Endpoint": "http://localhost:4317",
    "ServiceName": "nextraceone-apihost"
  },
  "Telemetry": {
    "ProductStore": {
      "ConnectionStringName": "NexTraceOne",
      "Schema": "telemetry",
      "EnableTimePartitioning": true,
      "MinuteMetricsPartitionInterval": "1 day",
      "HourlyMetricsPartitionInterval": "1 month"
    },
    "ObservabilityProvider": {
      "Provider": "ClickHouse",
      "ClickHouse": {
        "Enabled": true,
        "ConnectionString": "Host=localhost;Port=8123;Database=nextraceone_obs;Username=default;Password=",
        "Database": "nextraceone_obs",
        "LogsRetentionDays": 30,
        "TracesRetentionDays": 30,
        "MetricsRetentionDays": 90
      },
      "Elastic": {
        "Enabled": false,
        "Endpoint": "",
        "ApiKey": "",
        "IndexPrefix": "nextraceone",
        "LogsRetentionDays": 30,
        "TracesRetentionDays": 30,
        "MetricsRetentionDays": 90
      }
    },
    "CollectionMode": {
      "ActiveMode": "OpenTelemetryCollector",
      "OpenTelemetryCollector": {
        "Enabled": true,
        "OtlpGrpcEndpoint": "http://localhost:4317",
        "OtlpHttpEndpoint": "http://localhost:4318"
      },
      "ClrProfiler": {
        "Enabled": false,
        "Mode": "IIS",
        "ProfilerType": "AutoInstrumentation",
        "ExportTarget": "Collector",
        "OtlpEndpoint": "http://localhost:4317"
      }
    },
    "Collector": {
      "OtlpGrpcEndpoint": "http://localhost:4317",
      "OtlpHttpEndpoint": "http://localhost:4318",
      "MemoryLimitMb": 512,
      "MemorySpikeLimitMb": 128,
      "BatchSize": 8192,
      "BatchTimeoutMs": 5000,
      "TracesSamplingRate": 1.0
    },
    "Retention": {
      "RawTraces": {
        "HotDays": 7,
        "WarmDays": 30,
        "ColdDays": 0
      },
      "RawLogs": {
        "HotDays": 7,
        "WarmDays": 30,
        "ColdDays": 0
      },
      "MinuteAggregates": {
        "HotDays": 7,
        "WarmDays": 0,
        "ColdDays": 0
      },
      "HourlyAggregates": {
        "HotDays": 90,
        "WarmDays": 365,
        "ColdDays": 0
      },
      "Snapshots": {
        "HotDays": 90,
        "WarmDays": 365,
        "ColdDays": 0
      },
      "ObservedTopology": {
        "HotDays": 90,
        "WarmDays": 0,
        "ColdDays": 0
      },
      "AuditCompliance": {
