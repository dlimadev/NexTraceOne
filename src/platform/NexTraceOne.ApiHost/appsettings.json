{
  "ConnectionStrings": {
    "NexTraceOne": "Host=localhost;Port=5432;Database=nextraceone_operations;Username=nextraceone;Password=;Maximum Pool Size=10",
    "IdentityDatabase": "Host=localhost;Port=5432;Database=nextraceone_identity;Username=nextraceone;Password=;Maximum Pool Size=10",
    "CatalogDatabase": "Host=localhost;Port=5432;Database=nextraceone_catalog;Username=nextraceone;Password=;Maximum Pool Size=10",
    "ContractsDatabase": "Host=localhost;Port=5432;Database=nextraceone_catalog;Username=nextraceone;Password=;Maximum Pool Size=10",
    "DeveloperPortalDatabase": "Host=localhost;Port=5432;Database=nextraceone_catalog;Username=nextraceone;Password=;Maximum Pool Size=10",
    "ChangeIntelligenceDatabase": "Host=localhost;Port=5432;Database=nextraceone_operations;Username=nextraceone;Password=;Maximum Pool Size=10",
    "WorkflowDatabase": "Host=localhost;Port=5432;Database=nextraceone_operations;Username=nextraceone;Password=;Maximum Pool Size=10",
    "RulesetGovernanceDatabase": "Host=localhost;Port=5432;Database=nextraceone_operations;Username=nextraceone;Password=;Maximum Pool Size=10",
    "PromotionDatabase": "Host=localhost;Port=5432;Database=nextraceone_operations;Username=nextraceone;Password=;Maximum Pool Size=10",
    "IncidentDatabase": "Host=localhost;Port=5432;Database=nextraceone_operations;Username=nextraceone;Password=;Maximum Pool Size=10",
    "CostIntelligenceDatabase": "Host=localhost;Port=5432;Database=nextraceone_operations;Username=nextraceone;Password=;Maximum Pool Size=10",
    "RuntimeIntelligenceDatabase": "Host=localhost;Port=5432;Database=nextraceone_operations;Username=nextraceone;Password=;Maximum Pool Size=10",
    "ReliabilityDatabase": "Host=localhost;Port=5432;Database=nextraceone_operations;Username=nextraceone;Password=;Maximum Pool Size=10",
    "AuditDatabase": "Host=localhost;Port=5432;Database=nextraceone_identity;Username=nextraceone;Password=;Maximum Pool Size=10",
    "AiGovernanceDatabase": "Host=localhost;Port=5432;Database=nextraceone_ai;Username=nextraceone;Password=;Maximum Pool Size=10",
    "GovernanceDatabase": "Host=localhost;Port=5432;Database=nextraceone_operations;Username=nextraceone;Password=;Maximum Pool Size=10",
    "ExternalAiDatabase": "Host=localhost;Port=5432;Database=nextraceone_ai;Username=nextraceone;Password=;Maximum Pool Size=10",
    "AiOrchestrationDatabase": "Host=localhost;Port=5432;Database=nextraceone_ai;Username=nextraceone;Password=;Maximum Pool Size=10"
  },
  "NexTraceOne": {
    "IntegrityCheck": true,
    "PerformanceThresholdMs": 500,
    "Tenant": {
      "ResolutionStrategy": "JwtClaim"
    }
  },
  "Jwt": {
    "Issuer": "NexTraceOne",
    "Audience": "nextraceone-api",
    "Secret": "",
    "AccessTokenExpirationMinutes": 60,
    "RefreshTokenExpirationDays": 7
  },
  "AiRuntime": {
    "Ollama": {
      "BaseUrl": "http://localhost:11434",
      "TimeoutSeconds": 120,
      "MaxRetries": 2,
      "DefaultChatModel": "deepseek-r1:1.5b",
      "Enabled": true
    },
    "OpenAI": {
      "BaseUrl": "https://api.openai.com",
      "ApiKey": "",
      "DefaultChatModel": "gpt-4o-mini",
      "TimeoutSeconds": 60,
      "DefaultTemperature": 0.3,
      "DefaultMaxTokens": 2048,
      "Enabled": false
    },
    "Routing": {
      "PreferredProvider": "ollama",
      "PreferredChatModel": "deepseek-r1:1.5b",
      "EnableDeterministicFallback": true,
      "FallbackPrefix": "[FALLBACK_PROVIDER_UNAVAILABLE]"
    }
  },
  "Auth": {
    "CookieSession": {
      "Enabled": true,
      "AccessTokenCookieName": "nxt_at",
      "CsrfCookieName": "nxt_csrf",
      "CsrfHeaderName": "X-Csrf-Token",
      "AccessTokenCookieExpirationMinutes": 60,
      "RequireSecureCookies": true
    }
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:5173",
      "http://localhost:3000"
    ]
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "File",
        "Args": {
          "path": "logs/nextraceone-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 30
        }
      }
    ]
  },
  "OpenTelemetry": {
    "Endpoint": "http://localhost:4317",
    "ServiceName": "nextraceone-apihost"
  },
  "Telemetry": {
    "ProductStore": {
      "ConnectionStringName": "NexTraceOne",
      "Schema": "telemetry",
      "EnableTimePartitioning": true,
      "MinuteMetricsPartitionInterval": "1 day",
      "HourlyMetricsPartitionInterval": "1 month"
    },
    "TelemetryStore": {
      "TracesBackend": "tempo",
      "TracesEndpoint": "http://localhost:3200",
      "LogsBackend": "loki",
      "LogsEndpoint": "http://localhost:3100"
    },
    "Collector": {
      "OtlpGrpcEndpoint": "http://localhost:4317",
      "OtlpHttpEndpoint": "http://localhost:4318",
      "MemoryLimitMb": 512,
      "MemorySpikeLimitMb": 128,
      "BatchSize": 8192,
      "BatchTimeoutMs": 5000,
      "TracesSamplingRate": 1.0
    },
    "Retention": {
      "RawTraces": { "HotDays": 7, "WarmDays": 30, "ColdDays": 0 },
      "RawLogs": { "HotDays": 7, "WarmDays": 30, "ColdDays": 0 },
      "MinuteAggregates": { "HotDays": 7, "WarmDays": 0, "ColdDays": 0 },
      "HourlyAggregates": { "HotDays": 90, "WarmDays": 365, "ColdDays": 0 },
      "Snapshots": { "HotDays": 90, "WarmDays": 365, "ColdDays": 0 },
      "ObservedTopology": { "HotDays": 90, "WarmDays": 0, "ColdDays": 0 },
      "AuditCompliance": { "HotDays": 365, "WarmDays": 0, "ColdDays": 2555 }
    }
  }
}
