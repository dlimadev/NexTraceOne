{
  "ConnectionStrings": {
    "NexTraceOne": "Host=localhost;Port=5432;Database=nextraceone;Username=nextraceone;Password=ouro18"
  },
  "NexTraceOne": {
    "LicenseKey": "",
    "LicenseMode": "Online",
    "IntegrityCheck": false,
    "PerformanceThresholdMs": 500,
    "Tenant": {
      "ResolutionStrategy": "JwtClaim"
    }
  },
  "Jwt": {
    "Issuer": "NexTraceOne",
    "Audience": "nextraceone-api",
    "Secret": "",
    "AccessTokenExpirationMinutes": 60,
    "RefreshTokenExpirationDays": 7
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:5173",
      "http://localhost:3000"
    ]
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "File",
        "Args": {
          "path": "logs/nextraceone-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 30
        }
      }
    ]
  },
  "OpenTelemetry": {
    "Endpoint": "http://localhost:4317",
    "ServiceName": "nextraceone-apihost"
  },
  "Telemetry": {
    "ProductStore": {
      "ConnectionStringName": "NexTraceOne",
      "Schema": "telemetry",
      "EnableTimePartitioning": true,
      "MinuteMetricsPartitionInterval": "1 day",
      "HourlyMetricsPartitionInterval": "1 month"
    },
    "TelemetryStore": {
      "TracesBackend": "tempo",
      "TracesEndpoint": "http://localhost:3200",
      "LogsBackend": "loki",
      "LogsEndpoint": "http://localhost:3100"
    },
    "Collector": {
      "OtlpGrpcEndpoint": "http://localhost:4317",
      "OtlpHttpEndpoint": "http://localhost:4318",
      "MemoryLimitMb": 512,
      "MemorySpikeLimitMb": 128,
      "BatchSize": 8192,
      "BatchTimeoutMs": 5000,
      "TracesSamplingRate": 1.0
    },
    "Retention": {
      "RawTraces": { "HotDays": 7, "WarmDays": 30, "ColdDays": 0 },
      "RawLogs": { "HotDays": 7, "WarmDays": 30, "ColdDays": 0 },
      "MinuteAggregates": { "HotDays": 7, "WarmDays": 0, "ColdDays": 0 },
      "HourlyAggregates": { "HotDays": 90, "WarmDays": 365, "ColdDays": 0 },
      "Snapshots": { "HotDays": 90, "WarmDays": 365, "ColdDays": 0 },
      "ObservedTopology": { "HotDays": 90, "WarmDays": 0, "ColdDays": 0 },
      "AuditCompliance": { "HotDays": 365, "WarmDays": 0, "ColdDays": 2555 }
    }
  }
}
