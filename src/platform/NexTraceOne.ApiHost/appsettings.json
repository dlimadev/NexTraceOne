{
  "ConnectionStrings": {
    "NexTraceOne": "Host=localhost;Port=5432;Database=nextraceone;Username=nextraceone;Password=CHANGE_ME"
  },
  "NexTraceOne": {
    "LicenseKey": "",
    "LicenseMode": "Online",
    "IntegrityCheck": false,
    "PerformanceThresholdMs": 500,
    "Tenant": {
      "ResolutionStrategy": "JwtClaim"
    }
  },
  "Jwt": {
    "Issuer": "NexTraceOne",
    "Audience": "nextraceone-api",
    "Secret": "CHANGE_ME_TO_A_SECURE_KEY_AT_LEAST_32_CHARS_LONG!",
    "AccessTokenExpirationMinutes": 60,
    "RefreshTokenExpirationDays": 30
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:5173",
      "http://localhost:3000"
    ]
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "File",
        "Args": {
          "path": "logs/nextraceone-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 30
        }
      }
    ]
  },
  "OpenTelemetry": {
    "Endpoint": "http://localhost:4317",
    "ServiceName": "nextraceone-apihost"
  }
}
