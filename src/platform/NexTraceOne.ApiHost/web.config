<?xml version="1.0" encoding="utf-8"?>
<!--
  NexTraceOne — IIS Configuration
  
  Este ficheiro é usado quando a aplicação é hospedada no IIS (Windows Server).
  O ASP.NET Core Module (ANCM) faz o proxy de pedidos do IIS para o processo Kestrel.
  
  Pré-requisitos:
    - .NET 10 Hosting Bundle instalado
    - ASP.NET Core Module v2 (ANCM) registado no IIS
    - Application Pool configurado com "No Managed Code"
  
  Para mais informação: docs/deployment/PRODUCTION-BOOTSTRAP.md
-->
<configuration>
  <location path="." inheritInChildApplications="false">
    <system.webServer>
      <!-- ASP.NET Core Module — proxy para Kestrel -->
      <handlers>
        <add name="aspNetCore" path="*" verb="*" modules="AspNetCoreModuleV2" resourceType="Unspecified" />
      </handlers>

      <aspNetCore processPath="dotnet"
                  arguments=".\NexTraceOne.ApiHost.dll"
                  stdoutLogEnabled="false"
                  stdoutLogFile=".\logs\stdout"
                  hostingModel="InProcess">
        <environmentVariables>
          <!-- 
            Configurar variáveis de ambiente aqui ou via IIS Manager.
            OBRIGATÓRIO em produção:
              - ASPNETCORE_ENVIRONMENT=Production
              - Jwt__Secret=<your-secret>
              - Cors__AllowedOrigins__0=https://your-domain.com
              - ConnectionStrings__IdentityDatabase=<connection-string>
              - ConnectionStrings__CatalogDatabase=<connection-string>
              - ConnectionStrings__NexTraceOne=<connection-string>
              - ConnectionStrings__AiDatabase=<connection-string>
            
            OPCIONAL:
              - OpenTelemetry__Endpoint=http://otel-collector:4317
              - OllamaRuntime__Endpoint=http://ollama:11434
          -->
          <environmentVariable name="ASPNETCORE_ENVIRONMENT" value="Production" />
        </environmentVariables>
      </aspNetCore>

      <!-- Security headers -->
      <httpProtocol>
        <customHeaders>
          <remove name="X-Powered-By" />
          <add name="X-Content-Type-Options" value="nosniff" />
          <add name="X-Frame-Options" value="DENY" />
          <add name="X-XSS-Protection" value="0" />
          <add name="Referrer-Policy" value="strict-origin-when-cross-origin" />
          <add name="Permissions-Policy" value="camera=(), microphone=(), geolocation=()" />
        </customHeaders>
      </httpProtocol>

      <!-- Compressão -->
      <urlCompression doStaticCompression="true" doDynamicCompression="true" />

      <!-- Request limits -->
      <security>
        <requestFiltering>
          <!-- 30 MB max request size (para upload de contratos/schemas) -->
          <requestLimits maxAllowedContentLength="31457280" />
        </requestFiltering>
      </security>
    </system.webServer>
  </location>
</configuration>
