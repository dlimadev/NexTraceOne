{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "$description": "NexTraceOne Design System — Source of Truth tokens (Wave V3.5). Generated into Tailwind preset + CSS vars + TypeScript constants.",
  "color": {
    "brand": {
      "50":  { "$value": "#eef2ff", "$type": "color" },
      "100": { "$value": "#e0e7ff", "$type": "color" },
      "200": { "$value": "#c7d2fe", "$type": "color" },
      "300": { "$value": "#a5b4fc", "$type": "color" },
      "400": { "$value": "#818cf8", "$type": "color" },
      "500": { "$value": "#6366f1", "$type": "color" },
      "600": { "$value": "#4f46e5", "$type": "color" },
      "700": { "$value": "#4338ca", "$type": "color" },
      "800": { "$value": "#3730a3", "$type": "color" },
      "900": { "$value": "#312e81", "$type": "color" },
      "950": { "$value": "#1e1b4b", "$type": "color" }
    },
    "semantic": {
      "success": { "$value": "#22c55e", "$type": "color" },
      "warning": { "$value": "#f59e0b", "$type": "color" },
      "error":   { "$value": "#ef4444", "$type": "color" },
      "info":    { "$value": "#3b82f6", "$type": "color" }
    },
    "surface": {
      "default":  { "$value": "#ffffff", "$type": "color" },
      "subtle":   { "$value": "#f9fafb", "$type": "color" },
      "sunken":   { "$value": "#f3f4f6", "$type": "color" },
      "elevated": { "$value": "#ffffff", "$type": "color" }
    }
  },
  "spacing": {
    "xs":  { "$value": "4px",  "$type": "dimension" },
    "sm":  { "$value": "8px",  "$type": "dimension" },
    "md":  { "$value": "16px", "$type": "dimension" },
    "lg":  { "$value": "24px", "$type": "dimension" },
    "xl":  { "$value": "32px", "$type": "dimension" },
    "2xl": { "$value": "48px", "$type": "dimension" },
    "3xl": { "$value": "64px", "$type": "dimension" }
  },
  "typography": {
    "fontFamily": {
      "sans": { "$value": "Inter, ui-sans-serif, system-ui, sans-serif", "$type": "fontFamily" },
      "mono": { "$value": "JetBrains Mono, ui-monospace, monospace",     "$type": "fontFamily" }
    },
    "fontSize": {
      "xs":   { "$value": "11px", "$type": "dimension" },
      "sm":   { "$value": "13px", "$type": "dimension" },
      "base": { "$value": "14px", "$type": "dimension" },
      "md":   { "$value": "16px", "$type": "dimension" },
      "lg":   { "$value": "18px", "$type": "dimension" },
      "xl":   { "$value": "20px", "$type": "dimension" },
      "2xl":  { "$value": "24px", "$type": "dimension" }
    },
    "fontWeight": {
      "normal":   { "$value": "400", "$type": "fontWeight" },
      "medium":   { "$value": "500", "$type": "fontWeight" },
      "semibold": { "$value": "600", "$type": "fontWeight" },
      "bold":     { "$value": "700", "$type": "fontWeight" }
    },
    "lineHeight": {
      "tight":  { "$value": "1.25", "$type": "lineHeight" },
      "normal": { "$value": "1.5",  "$type": "lineHeight" },
      "loose":  { "$value": "1.75", "$type": "lineHeight" }
    }
  },
  "radius": {
    "none": { "$value": "0px",   "$type": "dimension" },
    "sm":   { "$value": "4px",   "$type": "dimension" },
    "md":   { "$value": "6px",   "$type": "dimension" },
    "lg":   { "$value": "8px",   "$type": "dimension" },
    "xl":   { "$value": "12px",  "$type": "dimension" },
    "full": { "$value": "9999px","$type": "dimension" }
  },
  "shadow": {
    "sm":  { "$value": "0 1px 2px rgba(0,0,0,.05)",                             "$type": "shadow" },
    "md":  { "$value": "0 4px 6px -1px rgba(0,0,0,.1)",                         "$type": "shadow" },
    "lg":  { "$value": "0 10px 15px -3px rgba(0,0,0,.1)",                       "$type": "shadow" },
    "xl":  { "$value": "0 20px 25px -5px rgba(0,0,0,.1)",                       "$type": "shadow" },
    "brand":{ "$value": "0 0 0 3px rgba(99,102,241,.35)",                       "$type": "shadow" }
  },
  "motion": {
    "duration": {
      "fast":   { "$value": "120ms", "$type": "duration" },
      "base":   { "$value": "180ms", "$type": "duration" },
      "medium": { "$value": "240ms", "$type": "duration" },
      "slow":   { "$value": "320ms", "$type": "duration" }
    },
    "easing": {
      "standard": { "$value": "cubic-bezier(0.2, 0, 0, 1)",     "$type": "cubicBezier" },
      "emphasis":  { "$value": "cubic-bezier(0.2, 0.8, 0.2, 1)", "$type": "cubicBezier" }
    }
  },
  "zIndex": {
    "base":     { "$value": "0",   "$type": "number" },
    "sticky":   { "$value": "20",  "$type": "number" },
    "header":   { "$value": "40",  "$type": "number" },
    "dropdown": { "$value": "60",  "$type": "number" },
    "modal":    { "$value": "80",  "$type": "number" },
    "toast":    { "$value": "100", "$type": "number" }
  }
}
