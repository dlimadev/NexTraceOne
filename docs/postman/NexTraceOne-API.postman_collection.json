    {
      "name": "04 - Contracts",
      "description": "Gestão de contratos OpenAPI: importação, versionamento, diff semântico.",
      "item": [
        {
          "name": "Import Contract",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  const json = pm.response.json();",
                  "  if (json.contractVersionId) pm.collectionVariables.set('contractVersionId', json.contractVersionId);",
                  "  pm.test('Contract imported', () => pm.response.to.have.status(201));",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{bearerToken}}" },
              { "key": "X-Tenant-Id", "value": "{{tenantId}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"apiAssetId\": \"{{apiAssetId}}\",\n  \"semVer\": \"1.0.0\",\n  \"specContent\": \"{\\\"openapi\\\":\\\"3.0.0\\\",\\\"info\\\":{\\\"title\\\":\\\"Payment API\\\",\\\"version\\\":\\\"1.0.0\\\"},\\\"paths\\\":{\\\"/payments\\\":{\\\"get\\\":{\\\"responses\\\":{\\\"200\\\":{\\\"description\\\":\\\"OK\\\"}}}}}}\",\n  \"format\": \"json\",\n  \"importedFrom\": \"upload\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/v1/contracts", "host": ["{{baseUrl}}"], "path": ["api","v1","contracts"] }
          }
        },
        {
          "name": "Create New Contract Version",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{bearerToken}}" },
              { "key": "X-Tenant-Id", "value": "{{tenantId}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"apiAssetId\": \"{{apiAssetId}}\",\n  \"semVer\": \"1.1.0\",\n  \"specContent\": \"{\\\"openapi\\\":\\\"3.0.0\\\",\\\"info\\\":{\\\"title\\\":\\\"Payment API\\\",\\\"version\\\":\\\"1.1.0\\\"},\\\"paths\\\":{\\\"/payments\\\":{\\\"get\\\":{\\\"responses\\\":{\\\"200\\\":{\\\"description\\\":\\\"OK\\\"}}}},\\\"/payments/refund\\\":{\\\"post\\\":{\\\"responses\\\":{\\\"201\\\":{\\\"description\\\":\\\"Created\\\"}}}}}}\",\n  \"format\": \"json\",\n  \"importedFrom\": \"upload\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/v1/contracts/versions", "host": ["{{baseUrl}}"], "path": ["api","v1","contracts","versions"] }
          }
        },
        {
          "name": "Compute Semantic Diff",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{bearerToken}}" },
              { "key": "X-Tenant-Id", "value": "{{tenantId}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"baseVersionId\": \"{{contractVersionId}}\",\n  \"targetVersionId\": \"<target-version-id>\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/v1/contracts/diff", "host": ["{{baseUrl}}"], "path": ["api","v1","contracts","diff"] }
          }
        },
        {
          "name": "Classify Breaking Change",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{bearerToken}}" },
              { "key": "X-Tenant-Id", "value": "{{tenantId}}" }
            ],
            "url": { "raw": "{{baseUrl}}/api/v1/contracts/{{contractVersionId}}/classification", "host": ["{{baseUrl}}"], "path": ["api","v1","contracts","{{contractVersionId}}","classification"] }
          }
        },
        {
          "name": "Suggest Semantic Version",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{bearerToken}}" },
              { "key": "X-Tenant-Id", "value": "{{tenantId}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/contracts/suggest-version?apiAssetId={{apiAssetId}}&changeLevel=2",
              "host": ["{{baseUrl}}"],
              "path": ["api","v1","contracts","suggest-version"],
              "query": [
                { "key": "apiAssetId", "value": "{{apiAssetId}}" },
                { "key": "changeLevel", "value": "2" }
              ]
            }
          }
        },
        {
          "name": "Get Contract History",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{bearerToken}}" },
              { "key": "X-Tenant-Id", "value": "{{tenantId}}" }
            ],
            "url": { "raw": "{{baseUrl}}/api/v1/contracts/history/{{apiAssetId}}", "host": ["{{baseUrl}}"], "path": ["api","v1","contracts","history","{{apiAssetId}}"] }
          }
        },
        {
          "name": "Lock Contract Version",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{bearerToken}}" },
              { "key": "X-Tenant-Id", "value": "{{tenantId}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"contractVersionId\": \"{{contractVersionId}}\",\n  \"lockedBy\": \"admin@nextraceone.com\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/v1/contracts/{{contractVersionId}}/lock", "host": ["{{baseUrl}}"], "path": ["api","v1","contracts","{{contractVersionId}}","lock"] }
          }
        },
        {
          "name": "Export Contract",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{bearerToken}}" },
              { "key": "X-Tenant-Id", "value": "{{tenantId}}" }
            ],
            "url": { "raw": "{{baseUrl}}/api/v1/contracts/{{contractVersionId}}/export", "host": ["{{baseUrl}}"], "path": ["api","v1","contracts","{{contractVersionId}}","export"] }
          }
        }
      ]
    },
    {
      "name": "05 - Change Intelligence",
      "description": "Core do produto: recepção de deploys, classificação de mudanças, blast radius e score de risco.",
      "item": [
        {
          "name": "Notify Deployment (Webhook CI/CD)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  const json = pm.response.json();",
                  "  if (json.releaseId) pm.collectionVariables.set('releaseId', json.releaseId);",
                  "  pm.test('Release created with Pending status', () => {",
                  "    pm.expect(json.status).to.equal('Pending');",
                  "    pm.expect(json.releaseId).to.be.a('string');",
                  "  });",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{bearerToken}}" },
              { "key": "X-Tenant-Id", "value": "{{tenantId}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"apiAssetId\": \"{{apiAssetId}}\",\n  \"serviceName\": \"payment-service\",\n  \"version\": \"1.1.0\",\n  \"environment\": \"staging\",\n  \"pipelineSource\": \"https://github.com/org/payment-service/actions/runs/123\",\n  \"commitSha\": \"abc123def456789012345678901234567890abcd\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/v1/releases", "host": ["{{baseUrl}}"], "path": ["api","v1","releases"] }
          }
        },
        {
          "name": "Get Release",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{bearerToken}}" },
              { "key": "X-Tenant-Id", "value": "{{tenantId}}" }
            ],
            "url": { "raw": "{{baseUrl}}/api/v1/releases/{{releaseId}}", "host": ["{{baseUrl}}"], "path": ["api","v1","releases","{{releaseId}}"] }
          }
        },
        {
          "name": "List Releases",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{bearerToken}}" },
              { "key": "X-Tenant-Id", "value": "{{tenantId}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/releases?apiAssetId={{apiAssetId}}&page=1&pageSize=20",
              "host": ["{{baseUrl}}"],
              "path": ["api","v1","releases"],
              "query": [
