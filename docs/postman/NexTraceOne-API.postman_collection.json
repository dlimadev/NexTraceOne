{
  "info": {
    "_postman_id": "nextraceone-api-collection-v1",
    "name": "NexTraceOne API",
    "description": "Coleção funcional de testes para todos os módulos da Sovereign Change Intelligence Platform NexTraceOne.\n\nBase URL: {{baseUrl}} (default: http://localhost:5000)\n\nAutenticação: Bearer token obtido via POST /api/v1/identity/auth/login",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:5000", "type": "string" },
    { "key": "bearerToken", "value": "", "type": "string" },
    { "key": "tenantId", "value": "00000000-0000-0000-0000-000000000001", "type": "string" },
    { "key": "userId", "value": "", "type": "string" },
    { "key": "apiAssetId", "value": "", "type": "string" },
    { "key": "serviceAssetId", "value": "", "type": "string" },
    { "key": "contractVersionId", "value": "", "type": "string" },
    { "key": "releaseId", "value": "", "type": "string" }
  ],
  "item": [
    {
      "name": "01 - Identity",
      "description": "Autenticação, gestão de utilizadores e controlo de acesso RBAC.",
      "item": [
        {
          "name": "Login Local",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  const json = pm.response.json();",
                  "  pm.collectionVariables.set('bearerToken', json.accessToken);",
                  "  pm.test('Login returned access token', () => { pm.expect(json.accessToken).to.be.a('string'); });",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "X-Tenant-Id", "value": "{{tenantId}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@nextraceone.com\",\n  \"password\": \"Admin@123!\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/v1/identity/auth/login", "host": ["{{baseUrl}}"], "path": ["api","v1","identity","auth","login"] }
          }
        },
        {
          "name": "Federated Login (OIDC)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "X-Tenant-Id", "value": "{{tenantId}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"provider\": \"AzureAD\",\n  \"idToken\": \"<oidc-id-token>\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/v1/identity/auth/federated", "host": ["{{baseUrl}}"], "path": ["api","v1","identity","auth","federated"] }
          }
        },
        {
          "name": "Refresh Token",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "X-Tenant-Id", "value": "{{tenantId}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"<refresh-token>\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/v1/identity/auth/refresh", "host": ["{{baseUrl}}"], "path": ["api","v1","identity","auth","refresh"] }
          }
        },
        {
          "name": "Revoke Session",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{bearerToken}}" },
              { "key": "X-Tenant-Id", "value": "{{tenantId}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"<refresh-token>\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/v1/identity/auth/revoke", "host": ["{{baseUrl}}"], "path": ["api","v1","identity","auth","revoke"] }
          }
        },
        {
          "name": "Create User",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  const json = pm.response.json();",
                  "  if (json.userId) pm.collectionVariables.set('userId', json.userId);",
                  "  pm.test('User created', () => pm.response.to.have.status(201));",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{bearerToken}}" },
              { "key": "X-Tenant-Id", "value": "{{tenantId}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"developer@nextraceone.com\",\n  \"firstName\": \"Dev\",\n  \"lastName\": \"User\",\n  \"password\": \"Dev@123!\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/v1/identity/users", "host": ["{{baseUrl}}"], "path": ["api","v1","identity","users"] }
          }
        },
        {
          "name": "Get User by ID",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{bearerToken}}" },
              { "key": "X-Tenant-Id", "value": "{{tenantId}}" }
            ],
            "url": { "raw": "{{baseUrl}}/api/v1/identity/users/{{userId}}", "host": ["{{baseUrl}}"], "path": ["api","v1","identity","users","{{userId}}"] }
          }
        },
        {
          "name": "Assign Role",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{bearerToken}}" },
              { "key": "X-Tenant-Id", "value": "{{tenantId}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"userId\": \"{{userId}}\",\n  \"role\": \"Developer\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/v1/identity/users/{{userId}}/roles", "host": ["{{baseUrl}}"], "path": ["api","v1","identity","users","{{userId}}","roles"] }
          }
        },
        {
          "name": "List Tenant Users",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{bearerToken}}" },
              { "key": "X-Tenant-Id", "value": "{{tenantId}}" }
            ],
            "url": { "raw": "{{baseUrl}}/api/v1/identity/tenants/{{tenantId}}/users", "host": ["{{baseUrl}}"], "path": ["api","v1","identity","tenants","{{tenantId}}","users"] }
          }
        }
      ]
    },
