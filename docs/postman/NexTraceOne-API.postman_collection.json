        {
          "name": "Get Usage Thresholds",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{bearerToken}}" },
              { "key": "X-Tenant-Id", "value": "{{tenantId}}" }
            ],
            "url": { "raw": "{{baseUrl}}/api/v1/licensing/thresholds", "host": ["{{baseUrl}}"], "path": ["api","v1","licensing","thresholds"] }
          }
        }
      ]
    },
    {
      "name": "03 - Engineering Graph",
      "description": "Catálogo de serviços e grafo de dependências.",
      "item": [
        {
          "name": "Register Service Asset",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  const json = pm.response.json();",
                  "  if (json.serviceAssetId) pm.collectionVariables.set('serviceAssetId', json.serviceAssetId);",
                  "  pm.test('Service asset created', () => pm.response.to.have.status(201));",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{bearerToken}}" },
              { "key": "X-Tenant-Id", "value": "{{tenantId}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"payment-service\",\n  \"team\": \"Payments Team\",\n  \"repository\": \"https://github.com/org/payment-service\",\n  \"environment\": \"production\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/v1/engineeringgraph/services", "host": ["{{baseUrl}}"], "path": ["api","v1","engineeringgraph","services"] }
          }
        },
        {
          "name": "Register API Asset",
          "event": [
            {
              "listen": "test",
              "script": {
