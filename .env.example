# ═══════════════════════════════════════════════════════════════════════════════
# NexTraceOne — Environment Configuration Template
#
# Copie este arquivo para .env e preencha os valores reais.
# NUNCA commitar o arquivo .env com valores reais.
# Este ficheiro é o template seguro para uso local/staging/production.
#
# Para gerar um JWT secret seguro:
#   openssl rand -base64 48
#
# Para gerar uma password de base de dados segura:
#   openssl rand -base64 32
# ═══════════════════════════════════════════════════════════════════════════════

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_USER=nextraceone
POSTGRES_PASSWORD=change-me-in-production
POSTGRES_DB=postgres

# ── Connection String (1 único banco físico) ──────────────────────────────────
# Architecture: 1 single physical PostgreSQL database `nextraceone`.
# All modules share the same database, isolated by table prefix per module:
#   iam_  Identity & Access       | env_  Environment Management
#   cfg_  Configuration           | cat_  Service Catalog
#   ctr_  Contracts               | chg_  Change Governance
#   ops_  Operational Intelligence| aud_  Audit & Compliance
#   gov_  Governance              | ntf_  Notifications
#   int_  Integrations            | pan_  Product Analytics
#   aik_  AI & Knowledge
#
# Format: Host=<host>;Port=5432;Database=nextraceone;Username=<user>;Password=<pass>;Maximum Pool Size=<n>
# Production: add SSL Mode=Require;Trust Server Certificate=false

CONNECTION_STRING_NEXTRACEONE=Host=postgres;Port=5432;Database=nextraceone;Username=nextraceone;Password=change-me-in-production;Maximum Pool Size=20

# ── JWT (OBRIGATÓRIO em Staging/Production) ───────────────────────────────────
# Mínimo 32 caracteres (HS256 key material). Gerar com: openssl rand -base64 48
JWT_SECRET=REPLACE-WITH-AT-LEAST-32-CHAR-SECRET-KEY
JWT_ISSUER=NexTraceOne
JWT_AUDIENCE=NexTraceOne

# ── Encryption at Rest (OBRIGATÓRIO em todos os ambientes) ────────────────────
# Chave AES-256-GCM para campos sensíveis no banco.
# Formato aceito: Base64 de 32 bytes OU string UTF-8 de 32 bytes.
# Gerar com: openssl rand -base64 32
NEXTRACE_ENCRYPTION_KEY=REPLACE-WITH-BASE64-32-BYTE-KEY

# ── API Host ─────────────────────────────────────────────────────────────────
APIHOST_PORT=8080
WORKERS_PORT=8081
INGESTION_PORT=8082
FRONTEND_PORT=3000

# ── Ambiente ─────────────────────────────────────────────────────────────────
# Development | Staging | Production
ASPNETCORE_ENVIRONMENT=Staging

# ── Migrations ───────────────────────────────────────────────────────────────
# Ativar auto-migrations apenas em Development (nunca em Production)
NEXTRACE_AUTO_MIGRATE=false

# ── OpenTelemetry ─────────────────────────────────────────────────────────────
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317
OTEL_SERVICE_NAME=nextraceone

# ── Observability Provider ────────────────────────────────────────────────────
# Provider de observabilidade: Elastic (default) ou ClickHouse (alternativa)
OBSERVABILITY_PROVIDER=Elastic
ELASTICSEARCH_ENDPOINT=http://elasticsearch:9200

# Para usar ClickHouse como provider alternativo:
# OBSERVABILITY_PROVIDER=ClickHouse
# CLICKHOUSE_PASSWORD=

# ── Analytics Writer ──────────────────────────────────────────────────────────
# O analytics writer segue automaticamente o OBSERVABILITY_PROVIDER configurado acima.
# Quando OBSERVABILITY_PROVIDER=Elastic, usa ElasticAnalyticsWriter (escrita em Elasticsearch).
# Quando OBSERVABILITY_PROVIDER=ClickHouse, usa ClickHouseAnalyticsWriter (escrita no ClickHouse).
ANALYTICS_ENABLED=true
# ConnectionString sobrescreve a inferida do provider quando definida explicitamente:
# ANALYTICS_CONNECTION_STRING=http://elasticsearch:9200

# ── Modo de Coleta ────────────────────────────────────────────────────────────
# Modo de coleta: OpenTelemetryCollector (Kubernetes) ou ClrProfiler (IIS/Windows)
COLLECTION_MODE=OpenTelemetryCollector

# ── AI Providers ─────────────────────────────────────────────────────────────
# Ollama local (padrão, não requer chave)
OLLAMA_ENDPOINT=http://localhost:11434

# OpenAI (opcional, governado por política)
OPENAI_API_KEY=

# ── CORS ─────────────────────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:3000

# ── Skip integrity check (apenas CI/CD — nunca em Production) ─────────────────
NEXTRACE_SKIP_INTEGRITY=false

# ═══════════════════════════════════════════════════════════════════════════════
# PRODUCTION-SPECIFIC SETTINGS
# ═══════════════════════════════════════════════════════════════════════════════
# As variáveis abaixo são usadas exclusivamente pelo workflow de produção
# e devem ser configuradas como GitHub Secrets/Variables no environment "production".
#
# GitHub Secrets (environment: production):
#   PRODUCTION_CONN_NEXTRACEONE  — Connection string completa para nextraceone
#
# GitHub Variables (environment: production):
#   PRODUCTION_APIHOST_URL       — URL pública do ApiHost (e.g., https://api.nextraceone.com)
#   PRODUCTION_FRONTEND_URL      — URL pública do Frontend (e.g., https://app.nextraceone.com)
#
# Runtime Environment Variables (no container de produção):
#   Jwt__Secret                  — JWT signing key (mínimo 32 caracteres)
#   ConnectionStrings__NexTraceOne — Connection string única para todos os módulos
#   ASPNETCORE_ENVIRONMENT=Production
#   NEXTRACE_SKIP_INTEGRITY=false
# ═══════════════════════════════════════════════════════════════════════════════
