# ═══════════════════════════════════════════════════════════════════════════════
# NexTraceOne — Environment Configuration Template
#
# Copie este arquivo para .env e preencha os valores reais.
# NUNCA commitar o arquivo .env com valores reais.
# Este ficheiro é o template seguro para uso local/staging/production.
#
# Para gerar um JWT secret seguro:
#   openssl rand -base64 48
#
# Para gerar uma password de base de dados segura:
#   openssl rand -base64 32
# ═══════════════════════════════════════════════════════════════════════════════

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_USER=nextraceone
POSTGRES_PASSWORD=change-me-in-production
POSTGRES_DB=postgres

# ── Connection Strings (4 bancos lógicos) ─────────────────────────────────────
# Formato: Host=<host>;Port=5432;Database=<db>;Username=<user>;Password=<pass>;Maximum Pool Size=<n>
# Production: adicionar SSL Mode=Require;Trust Server Certificate=false
#
# Os 19 connection strings do appsettings.json mapeiam para estes 4 bancos lógicos:
#   nextraceone_identity   → IdentityDatabase, AuditDatabase
#   nextraceone_catalog    → CatalogDatabase, ContractsDatabase, DeveloperPortalDatabase
#   nextraceone_operations → NexTraceOne, ChangeIntelligenceDatabase, WorkflowDatabase,
#                            RulesetGovernanceDatabase, PromotionDatabase, IncidentDatabase,
#                            CostIntelligenceDatabase, RuntimeIntelligenceDatabase,
#                            ReliabilityDatabase, GovernanceDatabase, AutomationDatabase
#   nextraceone_ai         → AiGovernanceDatabase, ExternalAiDatabase, AiOrchestrationDatabase

CONNECTION_STRING_IDENTITY=Host=postgres;Port=5432;Database=nextraceone_identity;Username=nextraceone;Password=change-me-in-production;Maximum Pool Size=10
CONNECTION_STRING_CATALOG=Host=postgres;Port=5432;Database=nextraceone_catalog;Username=nextraceone;Password=change-me-in-production;Maximum Pool Size=10
CONNECTION_STRING_OPERATIONS=Host=postgres;Port=5432;Database=nextraceone_operations;Username=nextraceone;Password=change-me-in-production;Maximum Pool Size=10
CONNECTION_STRING_AI=Host=postgres;Port=5432;Database=nextraceone_ai;Username=nextraceone;Password=change-me-in-production;Maximum Pool Size=10

# ── JWT (OBRIGATÓRIO em Staging/Production) ───────────────────────────────────
# Mínimo 32 caracteres (HS256 key material). Gerar com: openssl rand -base64 48
JWT_SECRET=REPLACE-WITH-AT-LEAST-32-CHAR-SECRET-KEY
JWT_ISSUER=NexTraceOne
JWT_AUDIENCE=NexTraceOne

# ── API Host ─────────────────────────────────────────────────────────────────
APIHOST_PORT=8080
WORKERS_PORT=8081
INGESTION_PORT=8082
FRONTEND_PORT=3000

# ── Ambiente ─────────────────────────────────────────────────────────────────
# Development | Staging | Production
ASPNETCORE_ENVIRONMENT=Staging

# ── Migrations ───────────────────────────────────────────────────────────────
# Ativar auto-migrations apenas em Development (nunca em Production)
NEXTRACE_AUTO_MIGRATE=false

# ── OpenTelemetry ─────────────────────────────────────────────────────────────
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317
OTEL_SERVICE_NAME=nextraceone

# ── Observability Provider ────────────────────────────────────────────────────
# Provider de observabilidade: ClickHouse (default) ou Elastic
OBSERVABILITY_PROVIDER=ClickHouse
CLICKHOUSE_PASSWORD=

# Para usar Elastic como provider (empresa com stack Elastic existente):
# OBSERVABILITY_PROVIDER=Elastic
# ELASTIC_ENDPOINT=https://elastic.example.com:9200
# ELASTIC_API_KEY=your-api-key

# ── Modo de Coleta ────────────────────────────────────────────────────────────
# Modo de coleta: OpenTelemetryCollector (Kubernetes) ou ClrProfiler (IIS/Windows)
COLLECTION_MODE=OpenTelemetryCollector

# ── AI Providers ─────────────────────────────────────────────────────────────
# Ollama local (padrão, não requer chave)
OLLAMA_ENDPOINT=http://localhost:11434

# OpenAI (opcional, governado por política)
OPENAI_API_KEY=

# ── CORS ─────────────────────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:3000

# ── Skip integrity check (apenas CI/CD — nunca em Production) ─────────────────
NEXTRACE_SKIP_INTEGRITY=false

# ═══════════════════════════════════════════════════════════════════════════════
# PRODUCTION-SPECIFIC SETTINGS
# ═══════════════════════════════════════════════════════════════════════════════
# As variáveis abaixo são usadas exclusivamente pelo workflow de produção
# (.github/workflows/production.yml) e devem ser configuradas como
# GitHub Secrets/Variables no environment "production".
#
# GitHub Secrets (environment: production):
#   PRODUCTION_CONN_IDENTITY     — Connection string completa para nextraceone_identity
#   PRODUCTION_CONN_CATALOG      — Connection string completa para nextraceone_catalog
#   PRODUCTION_CONN_OPERATIONS   — Connection string completa para nextraceone_operations
#   PRODUCTION_CONN_AI           — Connection string completa para nextraceone_ai
#
# GitHub Variables (environment: production):
#   PRODUCTION_APIHOST_URL       — URL pública do ApiHost (e.g., https://api.nextraceone.com)
#   PRODUCTION_FRONTEND_URL      — URL pública do Frontend (e.g., https://app.nextraceone.com)
#
# Runtime Environment Variables (no container de produção):
#   Jwt__Secret                  — JWT signing key (mínimo 32 caracteres)
#   ConnectionStrings__IdentityDatabase       — Connection string identity
#   ConnectionStrings__CatalogDatabase        — Connection string catalog
#   ConnectionStrings__NexTraceOne            — Connection string operations
#   ConnectionStrings__AiGovernanceDatabase   — Connection string AI
#   ASPNETCORE_ENVIRONMENT=Production
#   NEXTRACE_SKIP_INTEGRITY=false
# ═══════════════════════════════════════════════════════════════════════════════
