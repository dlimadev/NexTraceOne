{
  "_comment": "NexTraceOne — Elasticsearch Index Templates for observability and analytics data.",

  "observability_logs": {
    "index_patterns": ["nextraceone-obs-logs*"],
    "template": {
      "settings": {
        "number_of_shards": 1,
        "number_of_replicas": 0,
        "index.lifecycle.name": "nextraceone-obs-policy",
        "index.lifecycle.rollover_alias": "nextraceone-obs-logs"
      },
      "mappings": {
        "properties": {
          "@timestamp":           { "type": "date" },
          "trace_id":             { "type": "keyword" },
          "span_id":              { "type": "keyword" },
          "severity_text":        { "type": "keyword" },
          "severity_number":      { "type": "integer" },
          "body":                 { "type": "text" },
          "service.name":         { "type": "keyword" },
          "service.namespace":    { "type": "keyword" },
          "deployment.environment": { "type": "keyword" },
          "resource.attributes":  { "type": "object", "enabled": false },
          "attributes":           { "type": "object", "enabled": false }
        }
      }
    },
    "priority": 100
  },

  "observability_traces": {
    "index_patterns": ["nextraceone-obs-traces*"],
    "template": {
      "settings": {
        "number_of_shards": 1,
        "number_of_replicas": 0,
        "index.lifecycle.name": "nextraceone-obs-policy",
        "index.lifecycle.rollover_alias": "nextraceone-obs-traces"
      },
      "mappings": {
        "properties": {
          "@timestamp":           { "type": "date" },
          "trace_id":             { "type": "keyword" },
          "span_id":              { "type": "keyword" },
          "parent_span_id":       { "type": "keyword" },
          "name":                 { "type": "keyword" },
          "kind":                 { "type": "keyword" },
          "status.code":          { "type": "keyword" },
          "status.message":       { "type": "text" },
          "duration":             { "type": "long" },
          "service.name":         { "type": "keyword" },
          "service.namespace":    { "type": "keyword" },
          "deployment.environment": { "type": "keyword" },
          "resource.attributes":  { "type": "object", "enabled": false },
          "attributes":           { "type": "object", "enabled": false }
        }
      }
    },
    "priority": 100
  },

  "observability_metrics": {
    "index_patterns": ["nextraceone-obs-metrics*"],
    "template": {
      "settings": {
        "number_of_shards": 1,
        "number_of_replicas": 0,
        "index.lifecycle.name": "nextraceone-obs-policy",
        "index.lifecycle.rollover_alias": "nextraceone-obs-metrics"
      },
      "mappings": {
        "properties": {
          "@timestamp":           { "type": "date" },
          "metric.name":          { "type": "keyword" },
          "metric.type":          { "type": "keyword" },
          "metric.value":         { "type": "double" },
          "service.name":         { "type": "keyword" },
          "service.namespace":    { "type": "keyword" },
          "deployment.environment": { "type": "keyword" },
          "resource.attributes":  { "type": "object", "enabled": false },
          "attributes":           { "type": "object", "enabled": false }
        }
      }
    },
    "priority": 100
  },

  "analytics_pan_events": {
    "index_patterns": ["nextraceone-analytics-pan-events*"],
    "template": {
      "settings": {
        "number_of_shards": 1,
        "number_of_replicas": 0
      },
      "mappings": {
        "properties": {
          "id":               { "type": "keyword" },
          "tenant_id":        { "type": "keyword" },
          "user_id":          { "type": "keyword" },
          "persona":          { "type": "keyword" },
          "module":           { "type": "keyword" },
          "event_type":       { "type": "byte" },
          "feature":          { "type": "keyword" },
          "entity_type":      { "type": "keyword" },
          "outcome":          { "type": "keyword" },
          "route":            { "type": "keyword" },
          "team_id":          { "type": "keyword" },
          "domain_id":        { "type": "keyword" },
          "session_id":       { "type": "keyword" },
          "client_type":      { "type": "keyword" },
          "metadata_json":    { "type": "text", "index": false },
          "occurred_at":      { "type": "date" },
          "environment_id":   { "type": "keyword" },
          "duration_ms":      { "type": "long" },
          "parent_event_id":  { "type": "keyword" },
          "source":           { "type": "keyword" }
        }
      }
    },
    "priority": 100
  },

