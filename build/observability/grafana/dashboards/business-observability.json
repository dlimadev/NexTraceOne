{
  "__inputs": [],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "11.4.0" },
    { "type": "datasource", "id": "loki", "name": "Loki", "version": "1.0.0" }
  ],
  "annotations": { "list": [] },
  "description": "NexTraceOne Business Observability — snapshots ingeridos, drift findings detectados, releases analisadas, incidentes correlacionados.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": null,
  "links": [],
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "title": "Runtime Intelligence — Métricas de Produto",
      "type": "row"
    },
    {
      "datasource": { "type": "loki", "uid": "nextraceone-loki" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "blue", "value": null }
            ]
          }
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 1 },
      "id": 1,
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "center",
        "orientation": "horizontal",
        "reduceOptions": {
          "calcs": ["sum"],
          "fields": "",
          "values": false
        },
        "textMode": "auto"
      },
      "title": "Snapshots Ingeridos (24h)",
      "type": "stat",
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "nextraceone-loki" },
          "expr": "sum(count_over_time({application=\"NexTraceOne\"} |= \"IngestRuntimeSnapshot\" |= \"processed\" [$__range]))",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "loki", "uid": "nextraceone-loki" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 5 },
              { "color": "red", "value": 20 }
            ]
          }
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 1 },
      "id": 2,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "horizontal",
        "reduceOptions": {
          "calcs": ["sum"],
          "fields": "",
          "values": false
        },
        "textMode": "auto"
      },
      "title": "Drift Findings Detectados (24h)",
      "type": "stat",
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "nextraceone-loki" },
          "expr": "sum(count_over_time({application=\"NexTraceOne\"} |= \"drift detected\" [$__range]))",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "loki", "uid": "nextraceone-loki" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "blue", "value": null }
            ]
          }
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 1 },
      "id": 3,
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "center",
        "orientation": "horizontal",
        "reduceOptions": {
          "calcs": ["sum"],
          "fields": "",
          "values": false
        },
        "textMode": "auto"
      },
      "title": "Releases Comparadas (24h)",
      "type": "stat",
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "nextraceone-loki" },
          "expr": "sum(count_over_time({application=\"NexTraceOne\"} |= \"CompareReleaseRuntime\" [$__range]))",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "loki", "uid": "nextraceone-loki" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 5 }
            ]
          }
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 1 },
      "id": 4,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "horizontal",
        "reduceOptions": {
          "calcs": ["sum"],
          "fields": "",
          "values": false
        },
        "textMode": "auto"
      },
      "title": "Incidentes Correlacionados (24h)",
      "type": "stat",
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "nextraceone-loki" },
          "expr": "sum(count_over_time({application=\"NexTraceOne\"} |= \"CorrelationEngineTests\" or {application=\"NexTraceOne\"} |= \"incident correlated\" [$__range]))",
          "refId": "A"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 },
      "id": 101,
      "title": "Actividade por Ambiente",
      "type": "row"
    },
    {
      "datasource": { "type": "loki", "uid": "nextraceone-loki" },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 6 },
      "id": 10,
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "prettifyLogMessage": false,
        "showCommonLabels": false,
        "showLabels": true,
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": false
      },
      "title": "Runtime Intelligence Activity Logs",
      "type": "logs",
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "nextraceone-loki" },
          "expr": "{application=\"NexTraceOne\", environment=~\"$environment\"} |= \"runtime\" or {application=\"NexTraceOne\", environment=~\"$environment\"} |= \"drift\" or {application=\"NexTraceOne\", environment=~\"$environment\"} |= \"snapshot\"",
          "refId": "A"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 14 },
      "id": 102,
      "title": "Ingestion API",
      "type": "row"
    },
    {
      "datasource": { "type": "loki", "uid": "nextraceone-loki" },
      "gridPos": { "h": 6, "w": 24, "x": 0, "y": 15 },
      "id": 20,
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "prettifyLogMessage": false,
        "showCommonLabels": false,
        "showLabels": false,
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": false
      },
      "title": "Ingestion API Logs",
      "type": "logs",
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "nextraceone-loki" },
          "expr": "{application=\"NexTraceOne.Ingestion.Api\"}",
          "refId": "A"
        }
      ]
    }
  ],
  "refresh": "5m",
  "schemaVersion": 39,
  "tags": ["nextraceone", "business", "product", "observability"],
  "templating": {
    "list": [
      {
        "current": {},
        "hide": 0,
        "includeAll": true,
        "label": "Environment",
        "multi": false,
        "name": "environment",
        "options": [
          { "selected": false, "text": "All", "value": "$__all" },
          { "selected": false, "text": "dev", "value": "dev" },
          { "selected": false, "text": "test", "value": "test" },
          { "selected": false, "text": "qa", "value": "qa" },
          { "selected": false, "text": "uat", "value": "uat" },
          { "selected": false, "text": "staging", "value": "staging" },
          { "selected": true, "text": "production", "value": "production" }
        ],
        "query": "dev,test,qa,uat,staging,production",
        "type": "custom"
      }
    ]
  },
  "time": { "from": "now-24h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "NexTraceOne — Business Observability",
  "uid": "nextraceone-business-observability",
  "version": 1
}
