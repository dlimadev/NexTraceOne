{
  "__inputs": [],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "11.4.0" },
    { "type": "datasource", "id": "loki", "name": "Loki", "version": "1.0.0" },
    { "type": "datasource", "id": "tempo", "name": "Tempo", "version": "1.0.0" }
  ],
  "annotations": { "list": [] },
  "description": "NexTraceOne Runtime Environment Comparison — compara comportamento de runtime entre ambientes e releases, exibe drift findings e scores de observabilidade.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": null,
  "links": [],
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "title": "Drift Findings por Ambiente",
      "type": "row"
    },
    {
      "datasource": { "type": "loki", "uid": "nextraceone-loki" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 5 }
            ]
          }
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 1 },
      "id": 1,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "horizontal",
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "textMode": "auto"
      },
      "title": "Drift Findings — Critical/High",
      "type": "stat",
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "nextraceone-loki" },
          "expr": "sum(count_over_time({application=\"NexTraceOne\"} |= \"drift detected\" |= \"Critical\" [$__range]))",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "loki", "uid": "nextraceone-loki" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 }
            ]
          }
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 1 },
      "id": 2,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "horizontal",
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "textMode": "auto"
      },
      "title": "Drift Findings — Medium",
      "type": "stat",
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "nextraceone-loki" },
          "expr": "sum(count_over_time({application=\"NexTraceOne\"} |= \"drift detected\" |= \"Medium\" [$__range]))",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "loki", "uid": "nextraceone-loki" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 1 }
            ]
          }
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 1 },
      "id": 3,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "horizontal",
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "textMode": "auto"
      },
      "title": "DriftDetectionJob — Ciclos (24h)",
      "type": "stat",
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "nextraceone-loki" },
          "expr": "sum(count_over_time({application=\"NexTraceOne\"} |= \"DriftDetectionJob cycle complete\" [$__range]))",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "loki", "uid": "nextraceone-loki" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          }
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 1 },
      "id": 4,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "horizontal",
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "textMode": "auto"
      },
      "title": "DriftDetectionJob — Falhas (24h)",
      "type": "stat",
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "nextraceone-loki" },
          "expr": "sum(count_over_time({application=\"NexTraceOne\"} |= \"Drift detection cycle failed\" [$__range]))",
          "refId": "A"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 },
      "id": 101,
      "title": "Logs de Drift Detection por Ambiente",
      "type": "row"
    },
    {
      "datasource": { "type": "loki", "uid": "nextraceone-loki" },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 6 },
      "id": 10,
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "prettifyLogMessage": false,
        "showCommonLabels": false,
        "showLabels": false,
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": false
      },
      "title": "Drift Detection Logs",
      "type": "logs",
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "nextraceone-loki" },
          "expr": "{application=\"NexTraceOne\"} |= \"drift\"",
          "refId": "A"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 14 },
      "id": 102,
      "title": "Traces — Runtime Comparison",
      "type": "row"
    },
    {
      "datasource": { "type": "tempo", "uid": "nextraceone-tempo" },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 15 },
      "id": 20,
      "options": {
        "frameType": "TraceList"
      },
      "title": "Runtime Intelligence Traces",
      "type": "traces",
      "targets": [
        {
          "datasource": { "type": "tempo", "uid": "nextraceone-tempo" },
          "filters": [
            {
              "id": "service-name",
              "operator": "=",
              "scope": "resource",
              "tag": "service.name",
              "value": ["NexTraceOne"],
              "valueType": "string"
            }
          ],
          "limit": 20,
          "queryType": "traceql",
          "query": "{resource.service.name=\"NexTraceOne\" && name=~\"DetectRuntimeDrift|CompareReleaseRuntime|GetDriftFindings\"}",
          "refId": "A",
          "tableType": "traces"
        }
      ]
    }
  ],
  "refresh": "5m",
  "schemaVersion": 39,
  "tags": ["nextraceone", "runtime", "drift", "observability"],
  "templating": {
    "list": [
      {
        "current": {},
        "hide": 0,
        "includeAll": true,
        "label": "Environment",
        "multi": false,
        "name": "environment",
        "options": [
          { "selected": false, "text": "All", "value": "$__all" },
          { "selected": false, "text": "dev", "value": "dev" },
          { "selected": false, "text": "test", "value": "test" },
          { "selected": false, "text": "qa", "value": "qa" },
          { "selected": false, "text": "uat", "value": "uat" },
          { "selected": false, "text": "staging", "value": "staging" },
          { "selected": true, "text": "production", "value": "production" }
        ],
        "query": "dev,test,qa,uat,staging,production",
        "type": "custom"
      }
    ]
  },
  "time": { "from": "now-24h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "NexTraceOne — Runtime & Environment Comparison",
  "uid": "nextraceone-runtime-comparison",
  "version": 1
