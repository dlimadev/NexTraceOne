# ═══════════════════════════════════════════════════════════════════════════════
# NexTraceOne — Laboratory Environment Configuration
#
# Valores padrão funcionam out-of-the-box para desenvolvimento local.
# Copiar para .env se necessário: cp .env.lab .env
# ═══════════════════════════════════════════════════════════════════════════════

# ── Elasticsearch ──────────────────────────────────────────────────────────────
ELASTICSEARCH_ENDPOINT=http://elasticsearch:9200
ES_JAVA_OPTS=-Xms512m -Xmx512m

# ── Fake APIs ──────────────────────────────────────────────────────────────────
ORDER_SERVICE_PORT=5010
PAYMENT_SERVICE_PORT=5020
INVENTORY_SERVICE_PORT=5030

# ── OpenTelemetry ──────────────────────────────────────────────────────────────
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317
OTEL_SERVICE_NAMESPACE=nextraceone-lab

# ── Kibana ─────────────────────────────────────────────────────────────────────
KIBANA_PORT=5601
